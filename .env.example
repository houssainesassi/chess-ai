# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL example:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/chess
# Or use the Replit PostgreSQL URL copied from your Replit project secrets
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Ports (optional – defaults shown) ────────────────────────────────────────
# PORT=8080   (API server)
# PORT=5173   (Chess Board frontend – set separately when running that service)
